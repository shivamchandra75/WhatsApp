rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Other existing rules...
    
    // WebRTC Signaling rules for the 'calls' collection
    match /calls/{callId} {
      // Anyone authenticated can create a call
      allow create: if request.auth != null;
      // Only the caller or receiver can read the call document
      allow read: if request.auth != null && (request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.receiverId);
      // Only the receiver can update it (e.g., to answer) or the caller (e.g., to end)
      allow update: if request.auth != null && (request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.receiverId);
      // Either can delete the call when it ends
      allow delete: if request.auth != null && (request.auth.uid == resource.data.callerId || request.auth.uid == resource.data.receiverId);

      // SDP Offer subcollection
      match /offerCandidates/{document=**} {
        allow read, write: if request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId || request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.receiverId);
      }
      
      // SDP Answer subcollection
      match /answerCandidates/{document=**} {
        allow read, write: if request.auth != null && (request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.callerId || request.auth.uid == get(/databases/$(database)/documents/calls/$(callId)).data.receiverId);
      }
    }
  }
}
